text = input()
max_spaces = 0
current_spaces = 0

if text == "":
    print("Ошибка")
else:
    for simbol in range(0, len(text)):
        if text[simbol] == " ":
            current_spaces += 1
            if current_spaces > max_spaces:
                max_spaces = current_spaces
        else:
            current_spaces = 0

print("Максимальное количество пробелов:", max_spaces)
